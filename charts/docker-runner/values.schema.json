                "mountPath": {
                  "type": "string",
                  "minLength": 1,
                  "default": "/var/lib/docker"
                },
                "emptyDir": {
                  "type": "object",
                  "additionalProperties": true,
                  "default": {}
                },
                "persistentVolumeClaim": {
                  "type": "object",
                  "additionalProperties": true
                },
                "hostPath": {
                  "type": "object",
                  "additionalProperties": true
                },
                "subPath": {
                  "type": "string"
                },
                "readOnly": {
                  "type": "boolean",
